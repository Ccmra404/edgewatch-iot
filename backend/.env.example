MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_TOPIC=iot/devices/+/telemetry
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=change-me-in-production

# memory | sqlite
STORAGE_BACKEND=sqlite
SQLITE_PATH=/app/data/telemetry.db

# Optional: cap rows per device (memory deque + SQLite prune)
# MAX_TELEMETRY_PER_DEVICE=1000

# Set to 1 for local pytest (skip MQTT subscriber)
# DISABLE_MQTT=0
